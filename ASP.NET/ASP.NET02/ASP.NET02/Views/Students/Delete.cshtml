@model Students 
@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

<h2>Are you sure you wanto to delete this?</h2>
<h3>@Model.Name</h3>
<h3>@Model.Age</h3>

<form method="post" action="/Students/ConfirmDelete/@Model.Id">
    <input type="hidden" name="Id" value="@Model.Id"/>
    <input type="submit" value="Delete" class="btn btn-danger"/>
</form>
<a href="/Students/ShowAll">Back to list</a>
