@model StudentWithDeptsViewModel
@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<form method="post" action="/Students/SaveEdit/@Model.Id">
    <div>
        <input asp-for="Id" type="hidden" />
    </div>
    <div>
        <label>Name</label>
        <input asp-for="Name" class="form form-control" />
    </div>
    <div>
        <label>Age</label>
        <input asp-for="Age" class="form form-control" />
    </div>
    <div>
        <label>Department</label>
        <select name="DepartmentId" class="form form-control">
            @foreach (var item in Model.Departments)
                @if(Model.DepartmentId == item.Id)
                {
                    <option value="@item.Id" selected>@item.Name</option>
                }
                else
                {
                    <option value="@item.Id">@item.Name</option>
                }
        </select>    
    </div>
    <input type="submit" value="Save" class="btn btn-success mt-3 mb-3" />
</form>