@model List<Students>
@{
	ViewData["Title"] = "ShowAll";
	Layout = "_MyLayout";
}
<h1 style="color:whitesmoke">Students</h1>

<a href="/Students/Add" class=" btn btn-success mt-3 mb-3">New</a>
<table class="table  table-bordered" style="color:whitesmoke">
	<tr>
		<th>ID</th>
		<td>Name</td>
		<th>Age</th>
		<th>Department</th>
	</tr>
	@foreach(var item in Model)
	{	<tr>
			<td>@item.Id</td>
			<td>@item.Name</td>
			<td>@item.Age</td>
			<td>@item.Department.Name</td>
			<td><a href="/Students/Edit/@item.Id">Edit</a></td>
			<td><a href="/Students/Delete/@item.Id">Delete</a></td>
		</tr>
	}
</table>

<div class="mt-3">

    @if (ViewBag.CurrentPage > 1)
    {
        <a asp-action="ShowAll" asp-route-page="@(ViewBag.CurrentPage - 1)" class="btn btn-secondary">
            Previous
        </a>
    }

    @for (int i = 1; i <= ViewBag.TotalPages; i++)
    {
        <a asp-action="ShowAll" asp-route-page="@i"
           class="btn @(i == ViewBag.CurrentPage ? "btn-primary" : "btn-outline-primary")">
            @i
        </a>
    }

    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
    {
        <a asp-action="ShowAll" asp-route-page="@(ViewBag.CurrentPage + 1)" class="btn btn-secondary">
            Next
        </a>
    }

</div>