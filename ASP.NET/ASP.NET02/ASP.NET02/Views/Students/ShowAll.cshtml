@model List<Students>

<a href="/Students/Add" class=" btn btn-success mt-3 mb-3">New</a>
<table class="table table-hover table-bordered">
	<tr>
		<th>ID</th>
		<td>Name</td>
		<th>Age</th>
		<th>Department</th>
	</tr>
	@foreach(var item in Model)
	{	<tr>
			<td>@item.Id</td>
			<td>@item.Name</td>
			<td>@item.Age</td>
			<td>@item.Department.Name</td>
			<td><a href="/Students/Edit/@item.Id">Edit</a></td>
			<td><a href="/Students/Delete/@item.Id">Delete</a></td>
		</tr>
	}
</table>