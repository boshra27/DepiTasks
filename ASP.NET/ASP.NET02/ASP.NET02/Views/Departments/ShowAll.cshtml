@model List<Departments>
@{
    ViewData["Title"] = "ShowAll";
}

<h1>Departments</h1>

<a href="/Departments/Add" class=" btn btn-success mt-3 mb-3">New</a>
<table class="table table-hover table-bordered ">
    <tr>
        <td>ID</td>
        <td>Name</td>
        <td>Manager Name</td>
    </tr>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.Name</td>
            <td>@item.MgrName</td>
        </tr>
    }
</table>

