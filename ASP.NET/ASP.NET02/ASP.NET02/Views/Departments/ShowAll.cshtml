@model List<Departments>
@{
    ViewData["Title"] = "ShowAll";
    Layout = "_MyLayout";
}

<h1 style="color:whitesmoke">Departments</h1>

<a href="/Departments/Add" class=" btn btn-success mt-3 mb-3">New</a>
<table class="table table-bordered " style="color:whitesmoke">
    <tr>
        <td>ID</td>
        <td>Name</td>
        <td>Manager Name</td>
    </tr>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.Name</td>
            <td>@item.MgrName</td>
            <td><a asp-controller="Departments" asp-action="Edit" asp-route-id ="@item.Id">Edit</a></td>
        </tr>
    }
</table>
<div class="mt-3">

    @if (ViewBag.CurrentPage > 1)
    {
        <a asp-action="ShowAll" asp-route-page="@(ViewBag.CurrentPage - 1)" class="btn btn-secondary">
            Previous
        </a>
    }

    @for (int i = 1; i <= ViewBag.TotalPages; i++)
    {
        <a asp-action="ShowAll" asp-route-page="@i"
           class="btn @(i == ViewBag.CurrentPage ? "btn-primary" : "btn-outline-primary")">
            @i
        </a>
    }

    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
    {
        <a asp-action="ShowAll" asp-route-page="@(ViewBag.CurrentPage + 1)" class="btn btn-secondary">
            Next
        </a>
    }

</div>

